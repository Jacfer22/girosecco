# URL pubblica dell'app, senza slash finale
# Locale:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produzione (Vercel):
# NEXT_PUBLIC_SITE_URL=https://motogarage.info

# Supabase browser
NEXT_PUBLIC_SUPABASE_URL=https://TUO-PROGETTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=LA-TUA-ANON-KEY

# Solo server (consigliata): bypass RLS per admin e generazione in modalità service_role
# Se omessa, la generazione gemelli usa il JWT utente dopo migration_garage_generazione_utente.sql
# Supabase → Project Settings → API → service_role (secret, non anon)
SUPABASE_SERVICE_ROLE_KEY=LA-TUA-SERVICE-ROLE-KEY

# Solo server: generazione gemello AI (OBBLIGATORIO anche su Vercel)
# Crea un token su https://huggingface.co/settings/tokens (lettura)
HUGGINGFACE_TOKEN=hf_...

# Space Hugging Face per generazione (default: VAST-AI/TripoSplat)
# HF_GARAGE_SPACE=VAST-AI/TripoSplat

# Reel marketing: username garage pubblico per demo (no account personali)
# REEL_GARAGE_USER=demo
# REEL_BASE_URL=http://127.0.0.1:3000

# Marketing FLUX (opzionale, stesso token garage)
# HF_MARKETING_MODEL=black-forest-labs/FLUX.1-schnell

# Ideogram 4 — solo script locali Instagram (npm run social:ideogram), NON nell'app
# HF_IDEOGRAM_SPACE=ideogram-ai/ideogram4
